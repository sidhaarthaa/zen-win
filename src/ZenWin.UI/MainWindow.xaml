<Window x:Class="ZenWin.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ZenWin" Width="520" Height="300" MinWidth="460" MinHeight="260"
        Background="{StaticResource SurfaceBrush}">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="ZenWin" FontSize="28" FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}" />
            <TextBlock Text="Frameless window control" Margin="0,3,0,0"
                       Foreground="#68707D" />
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock Text="F10" FontSize="34" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,8" />
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap"
                       FontSize="15" Foreground="{StaticResource TextBrush}"
                       HorizontalAlignment="Center" TextAlignment="Center"
                       MaxWidth="420" />
        </StackPanel>
    </Grid>
</Window>
