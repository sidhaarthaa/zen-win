<Window x:Class="ZenWin.UI.ToolbarWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" Width="620" Height="64">
    <Border Background="#F2FFFFFF" BorderBrush="#D8DDE6" BorderThickness="1" CornerRadius="8" Padding="8">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="170" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Content="Exit Zen" Command="{Binding ToggleZenCommand}" />
            <Button Grid.Column="1" Content="Pin" />
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="Opacity" VerticalAlignment="Center" Margin="0,0,8,0" />
                <Slider Minimum="0.05" Maximum="0.6" Value="0.15" Width="90" />
            </StackPanel>
            <TextBlock Grid.Column="3" Text="{Binding TimerText, RelativeSource={RelativeSource AncestorType=Window}}" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="18" FontWeight="SemiBold" />
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="{Binding ClockText, RelativeSource={RelativeSource AncestorType=Window}}" Margin="8,0" />
                <TextBlock Text="{Binding BatteryText, RelativeSource={RelativeSource AncestorType=Window}}" Margin="8,0" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
